{
  "name": "lifi-cli",
  "version": "0.1.0",
  "description": "LI.FI CLI — bridge, swap, earn, and bet from the terminal. For humans and agents.",
  "bin": { "lifi": "./bin/lifi.js" },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".":         { "import": "./dist/index.js", "require": "./dist/index.cjs" },
    "./bridge":  { "import": "./dist/core/bridge/index.js" },
    "./swap":    { "import": "./dist/core/swap/index.js" },
    "./earn":    { "import": "./dist/core/earn/index.js" },
    "./markets": { "import": "./dist/core/markets/index.js" },
    "./agent":   { "import": "./dist/core/agent/index.js" },
    "./mcp":     { "import": "./dist/mcp/server.js" }
  },
  "files": ["dist", "bin"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node bin/lifi.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["lifi", "defi", "cli", "bridge", "swap", "earn", "yield", "polymarket"],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "axios": "^1.15.0",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "keytar": "^7.9.0",
    "openai": "^6.33.0",
    "ora": "^9.3.0",
    "viem": "^2.47.10"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.3"
  }
}
